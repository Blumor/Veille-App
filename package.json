{
  "name": "veille-cyber",
  "version": "0.1.0",
  "description": "Console de veille et de threat intelligence cyber — rapports quotidiens et hebdomadaires générés automatiquement.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "generate:daily": "node src/index.js daily",
    "generate:weekly": "node src/index.js weekly",
    "generate:monthly": "node src/index.js monthly"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "rss-parser": "^3.13.0"
  }
}
