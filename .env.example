# Clé API Anthropic (obligatoire pour la génération des rapports)
# À créer sur https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Modèle utilisé pour générer les rapports.
#   - claude-sonnet-4-6  : bon rapport qualité/coût (recommandé pour le quotidien)
#   - claude-opus-4-8    : qualité maximale (utile pour l'hebdo ou les synthèses lourdes)
VEILLE_MODEL=claude-sonnet-4-6

# Port du serveur web local
PORT=4317
